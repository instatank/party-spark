# =============================================================================
# Server-side AI keys (NOT shipped to the browser)
# =============================================================================
# These drive the /api/ai serverless proxy. They must NOT have the VITE_
# prefix — Vite only exposes VITE_-prefixed vars to the client bundle, and
# these keys should stay server-only.

# Google Gemini — used for all legacy / non-personalized AI generation
# and image features (Roast Me caricatures).
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (Haiku 4.5) — preferred provider for custom/personalized
# generation (Create Your Vibe in Most Likely To and Truth or Drink).
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# =============================================================================
# NOTE for local development with `npm run dev`:
# Vite's dev server does NOT run your /api/* serverless functions.
# To test AI-backed features locally, use `vercel dev` instead of `npm run dev`
# (install the Vercel CLI once: `npm install -g vercel`, then run `vercel dev`).
# =============================================================================
