# Google Gemini API key — used as the fallback provider and for image gen (Roast Me)
VITE_API_KEY=your_gemini_api_key_here

# Anthropic Claude API key — preferred provider for custom-generation features
# (Create Your Vibe for Most Likely To and Truth or Drink). Uses Haiku 4.5.
# Get one at: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-your_key_here
